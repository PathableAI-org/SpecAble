{
  "private": true,
  "license": "Unlicense",
  "type": "module",
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "codegen": "pnpm -r --filter @specable/domain --filter @specable/cli run codegen",
    "build": "tsc -b tsconfig.build.json && pnpm -r --filter @specable/domain --filter @specable/cli run build",
    "check": "tsc -b tsconfig.json",
    "typecheck": "pnpm check",
    "lint": "eslint \"**/{src,test,examples,scripts}/**/*.{ts,mjs}\"",
    "lint-fix": "pnpm lint --fix",
    "test": "vitest --config vitest.config.ts",
    "coverage": "vitest --config vitest.config.ts --coverage",
    "specable": "node packages/cli/bin/specable.js",
    "changeset": "changeset",
    "changeset-version": "changeset version",
    "changeset-pre-enter-alpha": "changeset pre enter alpha",
    "changeset-pre-exit": "changeset pre exit",
    "changeset-publish": "pnpm build && TEST_DIST= pnpm vitest && changeset publish",
    "prepare": "husky"
  },
  "lint-staged": {
    "{packages/*/{src,test,examples,scripts},scripts}/**/*.{ts,mjs}": "eslint --fix"
  },
  "devDependencies": {
    "@babel/cli": "^8.0.1",
    "@babel/core": "^8.0.1",
    "@babel/plugin-transform-export-namespace-from": "^8.0.1",
    "@babel/plugin-transform-modules-commonjs": "^8.0.1",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@effect/build-utils": "^0.8.9",
    "@effect/eslint-plugin": "^0.3.2",
    "@effect/language-service": "^0.86.2",
    "@effect/vitest": "^0.29.0",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "4.1.9",
    "babel-plugin-annotate-pure-calls": "^0.5.0",
    "effect": "^3.21.4",
    "eslint": "^10.5.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-perfectionist": "^5.9.1",
    "fallow": "^2.100.0",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
