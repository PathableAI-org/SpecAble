{
  "name": "@specable/domain",
  "version": "0.0.0",
  "type": "module",
  "license": "Unlicense",
  "description": "SpecAble domain — Effect Schema primitive models",
  "repository": {
    "type": "git",
    "url": "https://github.com/PathableAI-org/SpecAble.git",
    "directory": "packages/domain"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "scripts": {
    "codegen": "build-utils prepare-v2",
    "check": "tsc -b tsconfig.json"
  },
  "dependencies": {
    "@effect/schema": "^0.75.5",
    "effect": "^3.21.4"
  },
  "effect": {
    "generateExports": {
      "include": [
        "**/*.ts"
      ]
    },
    "generateIndex": {
      "include": [
        "*.ts",
        "unions/*.ts",
        "primitives/*.ts"
      ]
    }
  }
}
