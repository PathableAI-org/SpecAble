{
  "name": "@specable/cli",
  "version": "0.0.0",
  "type": "module",
  "license": "Unlicense",
  "description": "SpecAble CLI — local-first product primitive graph validation",
  "repository": {
    "type": "git",
    "url": "https://github.com/PathableAI-org/SpecAble.git",
    "directory": "packages/cli"
  },
  "bin": {
    "specable": "./bin/specable.js"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "scripts": {
    "codegen": "build-utils prepare-v2",
    "build": "pnpm build-esm && pnpm build-annotate && pnpm build-cjs && build-utils pack-v2 && cp bin/specable.js dist/bin/specable.js",
    "build-esm": "tsc -b tsconfig.build.json",
    "build-cjs": "babel build/esm --plugins @babel/transform-export-namespace-from --plugins @babel/transform-modules-commonjs --out-dir build/cjs --source-maps",
    "build-annotate": "babel build/esm --plugins annotate-pure-calls --out-dir build/esm --source-maps",
    "check": "tsc -b tsconfig.json",
    "prepare-examples": "tsx test/fixtures/project/runPrepareSqliteExamples.ts",
    "specable": "node ./bin/specable.js",
    "test": "vitest",
    "coverage": "vitest --coverage"
  },
  "dependencies": {
    "@specable/core": "workspace:*",
    "@specable/domain": "workspace:*",
    "@effect/cli": "^0.75.2",
    "@effect/platform": "^0.96.2",
    "@effect/platform-node": "^0.107.0",
    "@effect/schema": "^0.75.5",
    "effect": "^3.21.4"
  },
  "devDependencies": {
    "@effect/experimental": "^0.60.0",
    "@effect/sql": "^0.51.1",
    "@effect/sql-sqlite-node": "^0.52.0",
    "@effect/vitest": "^0.29.0",
    "tsx": "^4.22.4"
  },
  "effect": {
    "generateExports": {
      "include": [
        "**/*.ts"
      ]
    },
    "generateIndex": {
      "include": [
        "**/*.ts"
      ],
      "exclude": [
        "bin.ts",
        "validation/rules/**"
      ]
    }
  }
}
